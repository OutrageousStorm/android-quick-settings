#!/bin/bash
# quick-settings -- Fast Android settings manager via ADB
# Usage: quick-settings brightness 200
#        quick-settings airplane on
#        quick-settings list

set -e

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Quick presets
case "${1:-list}" in
  brightness)
    val="${2:-200}"
    adb shell settings put system screen_brightness "$val"
    echo -e "${GREEN}✓${NC} Brightness → $val"
    ;;
  airplane)
    state="${2:-toggle}"
    if [[ "$state" == "on" || "$state" == "1" ]]; then
      adb shell settings put global airplane_mode_on 1
      adb shell cmd connectivity airplane-mode enable
      echo -e "${GREEN}✓${NC} Airplane mode ON"
    elif [[ "$state" == "off" || "$state" == "0" ]]; then
      adb shell settings put global airplane_mode_on 0
      adb shell cmd connectivity airplane-mode disable
      echo -e "${GREEN}✓${NC} Airplane mode OFF"
    fi
    ;;
  wifi)
    state="${2:-toggle}"
    [[ "$state" == "on" || "$state" == "1" ]] && val=1 || val=0
    adb shell svc wifi "$([[ $val -eq 1 ]] && echo enable || echo disable)"
    echo -e "${GREEN}✓${NC} WiFi → $([[ $val -eq 1 ]] && echo ON || echo OFF)"
    ;;
  bluetooth)
    state="${2:-toggle}"
    [[ "$state" == "on" || "$state" == "1" ]] && val=1 || val=0
    adb shell svc bluetooth "$([[ $val -eq 1 ]] && echo enable || echo disable)"
    echo -e "${GREEN}✓${NC} Bluetooth → $([[ $val -eq 1 ]] && echo ON || echo OFF)"
    ;;
  nfc)
    [[ "$2" == "on" ]] && adb shell svc nfc enable || adb shell svc nfc disable
    echo -e "${GREEN}✓${NC} NFC toggled"
    ;;
  doze)
    adb shell dumpsys deviceidle step deep && adb shell dumpsys deviceidle step deep
    echo -e "${GREEN}✓${NC} Deep doze engaged"
    ;;
  rotation)
    val="${2:-0}"
    adb shell settings put system accelerometer_rotation "$val"
    echo -e "${GREEN}✓${NC} Rotation lock → $([[ $val -eq 0 ]] && echo ON || echo OFF)"
    ;;
  list)
    echo -e "${BOLD}Quick Settings${NC}"
    echo "  brightness <0-255>    Set screen brightness"
    echo "  airplane <on|off>     Toggle airplane mode"
    echo "  wifi <on|off>         Toggle WiFi"
    echo "  bluetooth <on|off>    Toggle Bluetooth"
    echo "  nfc <on|off>          Toggle NFC"
    echo "  doze                  Trigger deep doze"
    echo "  rotation <0|1>        Lock rotation (1=lock)"
    ;;
  *)
    echo "Unknown setting: $1"
    echo "Run: quick-settings list"
    ;;
esac
